__pycache__/
*.py[cod]

# Local environments and editor state
.env
.venv/
venv/
.idea/
.vscode/

# Large generated artifacts
*.pt
*.pth
*.ckpt
*.bin
*.safetensors
*.zip

# Experiment outputs are regenerated by smoke/core/full scripts.
logs/*
results/*
**/results/*
!logs/.gitkeep
!results/.gitkeep
!**/results/.gitkeep

# TensorBoard and cache directories
runs/
**/runs/
.cache/
**/.cache/
